<?xml version="1.0" encoding="UTF-8"?>

<?import io.github.palexdev.materialfx.controls.MFXButton?>
<?import io.github.palexdev.materialfx.controls.MFXPasswordField?>
<?import io.github.palexdev.materialfx.controls.MFXTextField?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane
        prefHeight="-1"
        prefWidth="-1"
        minWidth="800.0"
        minHeight="600.0"
        styleClass="root"
        stylesheets="@../css/loginsignupstyles.css"
        xmlns="http://javafx.com/javafx/17.0.12"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.example.auctionmanagementsystem.controller.LoginController">

    <top>
        <HBox
                styleClass="titlePane"
                alignment="CENTER_LEFT"
                prefHeight="88.0"
                spacing="14.0"
                BorderPane.alignment="CENTER">
            <padding><Insets top="0" right="28" bottom="0" left="28"/></padding>

            <Label text="Auction System" styleClass="titleLabel">
                <font><Font name="Berlin Sans FB" size="46.0"/></font>
            </Label>

            <Region HBox.hgrow="ALWAYS"/>

            <Label text="Don't have an account?" styleClass="loggedInText">
                <font><Font size="15.0"/></font>
            </Label>
            <MFXButton
                    fx:id="signupButton"
                    onAction="#onSignupButtonClick"
                    styleClass="outlineButton"
                    text="Sign Up"
                    prefWidth="110.0"
                    prefHeight="38.0"/>
        </HBox>
    </top>

    <center>
        <StackPane styleClass="loginBackground">

            <HBox alignment="CENTER" spacing="0"
                  styleClass="loginCard"
                  maxWidth="920.0" maxHeight="520.0"
                  StackPane.alignment="CENTER">

                <!-- LEFT PANEL -->
                <VBox
                        styleClass="loginLeftPanel"
                        alignment="CENTER"
                        spacing="20"
                        prefWidth="400.0">
                    <padding><Insets top="48" right="40" bottom="48" left="40"/></padding>

                    <Label text="Welcome Back" styleClass="loginWelcomeTitle">
                        <font><Font name="Berlin Sans FB" size="36.0"/></font>
                    </Label>
                    <Label text="Sign in to access your auctions, bids and watchlist."
                           styleClass="loginWelcomeSub"
                           wrapText="true"
                           textAlignment="CENTER">
                        <font><Font size="14.0"/></font>
                    </Label>

                    <Region prefHeight="10"/>

                    <HBox spacing="20" alignment="CENTER">
                        <VBox alignment="CENTER" spacing="4">
                            <Label fx:id="statListings" text="1200+" styleClass="statNumLabel">
                                <font><Font name="Berlin Sans FB" size="22.0"/></font>
                            </Label>
                            <Label text="Active Listings" styleClass="statTextLabel">
                                <font><Font size="12.0"/></font>
                            </Label>
                        </VBox>
                        <Separator orientation="VERTICAL" styleClass="statDivider"/>
                        <VBox alignment="CENTER" spacing="4">
                            <Label fx:id="statMembers" text="5800+" styleClass="statNumLabel">
                                <font><Font name="Berlin Sans FB" size="22.0"/></font>
                            </Label>
                            <Label text="Members" styleClass="statTextLabel">
                                <font><Font size="12.0"/></font>
                            </Label>
                        </VBox>
                        <Separator orientation="VERTICAL" styleClass="statDivider"/>
                        <VBox alignment="CENTER" spacing="4">
                            <Label fx:id="statBids" text="2M+" styleClass="statNumLabel">
                                <font><Font name="Berlin Sans FB" size="22.0"/></font>
                            </Label>
                            <Label text="Total Bids" styleClass="statTextLabel">
                                <font><Font size="12.0"/></font>
                            </Label>
                        </VBox>
                    </HBox>
                </VBox>

                <Separator orientation="VERTICAL" styleClass="panelDivider"/>

                <!-- RIGHT PANEL -->
                <VBox
                        styleClass="loginRightPanel"
                        alignment="CENTER"
                        spacing="16"
                        prefWidth="420.0">
                    <padding><Insets top="48" right="48" bottom="48" left="48"/></padding>

                    <Label text="Login" styleClass="loginFormTitle">
                        <font><Font name="Berlin Sans FB" size="38.0"/></font>
                    </Label>
                    <Label text="Enter your credentials to continue" styleClass="loginFormSub">
                        <font><Font size="13.0"/></font>
                    </Label>

                    <Region prefHeight="8"/>

                    <!-- Username -->
                    <VBox spacing="6" maxWidth="Infinity">
                        <Label text="Username" styleClass="fieldLabel"/>
                        <MFXTextField
                                fx:id="usernameField"
                                styleClass="signupField"
                                promptText="Enter your username"
                                prefHeight="48.0"
                                maxWidth="Infinity"/>
                        <Label fx:id="unValidLabel"
                               styleClass="errorLabel"
                               text="" visible="false"/>
                    </VBox>

                    <!-- Password -->
                    <VBox spacing="6" maxWidth="Infinity">
                        <Label text="Password" styleClass="fieldLabel"/>
                        <MFXPasswordField
                                fx:id="passwordField"
                                styleClass="signupField"
                                promptText="Enter your password"
                                prefHeight="48.0"
                                maxWidth="Infinity"/>
                        <Label fx:id="pwValidLabel"
                               styleClass="errorLabel"
                               text="" visible="false"/>
                    </VBox>

                    <!-- Forgot password -->
                    <HBox alignment="CENTER_RIGHT">
                        <MFXButton
                                fx:id="forgotPassButton"
                                onAction="#onForgotPassClick"
                                styleClass="forgotLink"
                                text="Forgot Password?"/>
                    </HBox>

                    <!-- Login Button -->
                    <MFXButton
                            fx:id="loginButton"
                            onAction="#onLoginButtonClick"
                            styleClass="goldButton signupSubmitBtn"
                            text="Login"
                            prefHeight="50.0"
                            maxWidth="Infinity"/>

                    <!-- Divider -->
                    <HBox alignment="CENTER" spacing="12">
                        <Separator HBox.hgrow="ALWAYS"/>
                        <Label text="or" styleClass="orLabel"/>
                        <Separator HBox.hgrow="ALWAYS"/>
                    </HBox>

                    <!-- Signup link -->
                    <HBox alignment="CENTER" spacing="6">
                        <Label text="Don't have an account?" styleClass="loginFormSub"/>
                        <Label text="Sign Up"
                               styleClass="termsLink"
                               onMouseClicked="#onSignupClick"/>
                    </HBox>

                </VBox>
            </HBox>
        </StackPane>
    </center>

</BorderPane>