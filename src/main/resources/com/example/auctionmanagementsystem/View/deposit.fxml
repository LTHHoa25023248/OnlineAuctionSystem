<?xml version="1.0" encoding="UTF-8"?>

<?import io.github.palexdev.materialfx.controls.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane
        prefWidth="860.0"
        prefHeight="620.0"
        styleClass="root"
        xmlns="http://javafx.com/javafx/17.0.12"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.example.auctionmanagementsystem.controller.DepositController">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="68.0"
              style="-fx-background-color: #080A0F;
                     -fx-border-color: transparent transparent rgba(212,168,58,0.28) transparent;
                     -fx-border-width: 0 0 1px 0;
                     -fx-padding: 0 32px;">
            <Label text="Deposit Funds"
                   style="-fx-text-fill: #F0C060; -fx-font-family: Georgia;
                          -fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <MFXButton fx:id="closeButton" styleClass="closeButton"
                       onAction="#handleClose" prefHeight="34.0" prefWidth="34.0">
                <graphic>
                    <ImageView fitHeight="16.0" fitWidth="16.0"
                               pickOnBounds="true" preserveRatio="true">
                        <image><Image url="@../images/Icons/cross-circle.png"/></image>
                    </ImageView>
                </graphic>
            </MFXButton>
        </HBox>
    </top>

    <center>
        <HBox style="-fx-background-color: #0D1018;">

            <VBox alignment="TOP_CENTER" spacing="0"
                  prefWidth="300.0" minWidth="260.0"
                  style="-fx-background-color: linear-gradient(to bottom, #131720, #0D1018);
                         -fx-border-color: transparent rgba(255,255,255,0.06) transparent transparent;
                         -fx-border-width: 0 1px 0 0;">
                <padding><Insets top="56" right="36" bottom="48" left="36"/></padding>

                <StackPane prefWidth="80.0" prefHeight="80.0" alignment="CENTER"
                           style="-fx-background-color: rgba(212,168,58,0.10);
                                  -fx-background-radius: 999px;
                                  -fx-border-color: rgba(212,168,58,0.22);
                                  -fx-border-radius: 999px;
                                  -fx-border-width: 1px;">
                    <ImageView fitHeight="36.0" fitWidth="36.0"
                               pickOnBounds="true" preserveRatio="true">
                        <image><Image url="@../images/Icons/dollar-symbol.png"/></image>
                    </ImageView>
                </StackPane>

                <Region prefHeight="28.0"/>
                <Label text="Add Funds"
                       style="-fx-text-fill: #F0C060; -fx-font-family: Georgia;
                              -fx-font-size: 20px; -fx-font-weight: bold;"
                       textAlignment="CENTER" wrapText="true"/>
                <Region prefHeight="8.0"/>
                <Label text="Funds are added instantly to your auction wallet."
                       style="-fx-text-fill: rgba(168,164,156,0.55); -fx-font-size: 12px;"
                       wrapText="true" textAlignment="CENTER"/>
                <Region prefHeight="36.0"/>

                <VBox spacing="8" maxWidth="Infinity"
                      style="-fx-background-color: rgba(212,168,58,0.07);
                             -fx-background-radius: 12px;
                             -fx-border-color: rgba(212,168,58,0.20);
                             -fx-border-radius: 12px;
                             -fx-border-width: 1px;
                             -fx-padding: 20px 22px;">
                    <Label text="CURRENT BALANCE"
                           style="-fx-text-fill: rgba(168,164,156,0.42);
                                  -fx-font-size: 10px; -fx-font-weight: bold;"/>
                    <Label fx:id="balanceLabel" text="0.00 USD"
                           style="-fx-text-fill: #F0C060; -fx-font-family: Georgia;
                                  -fx-font-size: 26px; -fx-font-weight: bold;"/>
                    <Label text="Available for bidding"
                           style="-fx-text-fill: rgba(168,164,156,0.38); -fx-font-size: 11px;"/>
                </VBox>
            </VBox>

            <VBox spacing="0" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: #0D1018;">
                <padding><Insets top="56" right="72" bottom="56" left="60"/></padding>

                <Label text="Select Amount"
                       style="-fx-text-fill: #F2F0EC; -fx-font-family: Georgia;
                              -fx-font-size: 22px; -fx-font-weight: bold;"/>
                <Region prefHeight="6.0"/>
                <Label text="Choose a preset amount or enter a custom value below"
                       style="-fx-text-fill: rgba(168,164,156,0.52); -fx-font-size: 13px;"/>
                <Region prefHeight="32.0"/>

                <Label text="QUICK SELECT"
                       style="-fx-text-fill: rgba(168,164,156,0.80);
                              -fx-font-size: 12px; -fx-font-weight: bold;"/>
                <Region prefHeight="12.0"/>

                <HBox spacing="10">
                    <MFXButton fx:id="btn10"  styleClass="goldButton" text="10"
                               onAction="#onQuickAmount" prefHeight="48.0"
                               HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    <MFXButton fx:id="btn50"  styleClass="goldButton" text="50"
                               onAction="#onQuickAmount" prefHeight="48.0"
                               HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    <MFXButton fx:id="btn100" styleClass="goldButton" text="100"
                               onAction="#onQuickAmount" prefHeight="48.0"
                               HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    <MFXButton fx:id="btn500" styleClass="goldButton" text="500"
                               onAction="#onQuickAmount" prefHeight="48.0"
                               HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                </HBox>
                <Region prefHeight="10.0"/>
                <HBox spacing="10">
                    <MFXButton fx:id="btn1000"  styleClass="goldButton" text="1000"
                               onAction="#onQuickAmount" prefHeight="48.0"
                               HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    <MFXButton fx:id="btn2000"  styleClass="goldButton" text="2000"
                               onAction="#onQuickAmount" prefHeight="48.0"
                               HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    <MFXButton fx:id="btn5000"  styleClass="goldButton" text="5000"
                               onAction="#onQuickAmount" prefHeight="48.0"
                               HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    <MFXButton fx:id="btn10000" styleClass="goldButton" text="10000"
                               onAction="#onQuickAmount" prefHeight="48.0"
                               HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                </HBox>

                <Region prefHeight="32.0"/>
                <HBox alignment="CENTER" spacing="14">
                    <Separator HBox.hgrow="ALWAYS"
                               style="-fx-background-color: rgba(255,255,255,0.07);"/>
                    <Label text="OR ENTER MANUALLY"
                           style="-fx-text-fill: rgba(168,164,156,0.38);
                                  -fx-font-size: 10px; -fx-font-weight: bold;"/>
                    <Separator HBox.hgrow="ALWAYS"
                               style="-fx-background-color: rgba(255,255,255,0.07);"/>
                </HBox>

                <Region prefHeight="24.0"/>
                <Label text="CUSTOM AMOUNT (USD)"
                       style="-fx-text-fill: rgba(168,164,156,0.80);
                              -fx-font-size: 12px; -fx-font-weight: bold;"/>
                <Region prefHeight="8.0"/>
                <MFXTextField fx:id="amountField" styleClass="signupField"
                              promptText="Enter amount in USD"
                              prefHeight="54.0" maxWidth="Infinity"/>
                <Region prefHeight="8.0"/>
                <Label fx:id="validationLabel" styleClass="errorLabel"
                       text="" wrapText="true" maxWidth="Infinity"/>
                <Region prefHeight="28.0"/>
                <MFXButton fx:id="depositButton"
                           styleClass="goldButton signupSubmitBtn"
                           text="Deposit Now"
                           onAction="#handleDeposit"
                           prefHeight="54.0" maxWidth="Infinity"/>
            </VBox>

        </HBox>
    </center>

</BorderPane>